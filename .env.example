# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The ID of the channel where event submissions and reports will be posted
# Right-click the channel in Discord > Copy Channel ID (requires Developer Mode)
LOG_CHANNEL_ID=your_channel_id_here

# How often (in minutes) the bot checks for past events and sends follow-up DMs
# Default: 30
CHECK_INTERVAL_MINUTES=30
